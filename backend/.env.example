# Environment Variables for DarshanEase Backend
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000

# Database Configuration
# For local MongoDB: mongodb://localhost:27017/darshanease
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/darshanease
MONGO_URI=mongodb://localhost:27017/darshanease

# JWT Secret Key (Use a strong, random secret in production)
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production

# Optional: Email Configuration (for future features)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password